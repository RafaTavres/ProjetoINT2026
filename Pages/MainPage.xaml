<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             xmlns:pages="clr-namespace:ProjetoINT2026.Pages"
             xmlns:services="clr-namespace:ProjetoINT2026.Services"
             x:Class="ProjetoINT2026.Pages.MainPage"
             x:DataType="pages:MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF8">

    <ContentPage.Resources>
        <Color x:Key="Sage">#AFC0A3</Color>
        <Color x:Key="SageDark">#66745C</Color>
        <Color x:Key="BodyText">#343A32</Color>
        <Color x:Key="SoftText">#7E877A</Color>
        <Color x:Key="Line">#E4E7E0</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,88">
        <Grid Grid.Row="0"
              RowDefinitions="104,42,218,34,*"
              Padding="26,40,26,0">
            <Grid>
                <VerticalStackLayout Spacing="3"
                                     VerticalOptions="Center">
                    <Label Text="Feed"
                           TextColor="{StaticResource SageDark}"
                           FontSize="32"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold" />
                    <Label Text="Notícias e artigos para estudar enfermagem"
                           TextColor="{StaticResource SoftText}"
                           FontSize="13" />
                    <Label x:Name="FeedStatusLabel"
                           Text="Carregando feed..."
                           TextColor="{StaticResource SoftText}"
                           FontSize="11" />
                </VerticalStackLayout>
            </Grid>

            <Border Grid.Row="1"
                    BackgroundColor="#EEF4EC"
                    Stroke="#DDE7DA"
                    StrokeThickness="1"
                    Padding="13,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Label Text="Conteúdo educativo. Não substitui orientação profissional ou protocolos da instituição."
                       TextColor="{StaticResource SageDark}"
                       FontSize="11"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
            </Border>

            <Border Grid.Row="2"
                    BindingContext="{Binding FeaturedPost}"
                    BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    Margin="0,12,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPostTapped" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,8"
                            Radius="18"
                            Opacity="0.16" />
                </Border.Shadow>
                <Grid RowDefinitions="146,*"
                      x:DataType="services:HealthPost">
                    <Grid>
                        <Image Source="{Binding ImageUrl}"
                               IsVisible="{Binding HasImage}"
                               Aspect="AspectFill" />
                        <Grid IsVisible="{Binding HasNoImage}"
                              BackgroundColor="#DDE7DA">
                            <Label Text="Florence Feed"
                                   TextColor="{StaticResource SageDark}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Grid>
                        <Border BackgroundColor="#EEF4EC"
                                StrokeThickness="0"
                                Padding="9,4"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                Margin="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding TypeLabel}"
                                   TextColor="{StaticResource SageDark}"
                                   FontSize="10"
                                   FontAttributes="Bold" />
                        </Border>
                        <Border BackgroundColor="#FFFFFF"
                                StrokeThickness="0"
                                Padding="9,4"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="Destaque"
                                   TextColor="{StaticResource SageDark}"
                                   FontSize="10"
                                   FontAttributes="Bold" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1"
                                         Padding="14,10"
                                         Spacing="5">
                        <Label Text="{Binding Title}"
                               TextColor="{StaticResource SageDark}"
                               FontSize="17"
                               FontAttributes="Bold"
                               LineBreakMode="WordWrap"
                               MaxLines="2" />
                        <Label Text="{Binding SourceLine}"
                               TextColor="{StaticResource SoftText}"
                               FontSize="11" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto"
                  Margin="0,12,0,0">
                <Label Text="Mais conteúdos"
                       TextColor="{StaticResource BodyText}"
                       FontSize="18"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="puxe para atualizar"
                       TextColor="{StaticResource SoftText}"
                       FontSize="11"
                       VerticalOptions="Center" />
            </Grid>

            <RefreshView Grid.Row="4"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         Margin="0,8,0,12">
                <CollectionView ItemsSource="{Binding Posts}"
                                SelectionMode="None">
                    <CollectionView.Footer>
                        <BoxView HeightRequest="18"
                                 Color="Transparent" />
                    </CollectionView.Footer>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="0,40"
                                             Spacing="10"
                                             HorizontalOptions="Center">
                            <ActivityIndicator IsRunning="True"
                                               Color="{StaticResource Sage}" />
                            <Label Text="Buscando conteudos..."
                                   TextColor="{StaticResource SoftText}"
                                   FontSize="13"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="10"
                                         VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:HealthPost">
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPostTapped" />
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="#16000000"
                                            Offset="0,5"
                                            Radius="12"
                                            Opacity="0.14" />
                                </Border.Shadow>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid RowDefinitions="104,*"
                                      HeightRequest="222">
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}"
                                               IsVisible="{Binding HasImage}"
                                               Aspect="AspectFill" />
                                        <Grid IsVisible="{Binding HasNoImage}"
                                              BackgroundColor="#EEF4EC">
                                            <Label Text="{Binding TypeLabel}"
                                                   TextColor="{StaticResource SageDark}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                        <Border BackgroundColor="#FFFFFF"
                                                StrokeThickness="0"
                                                Padding="8,3"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                Margin="8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="9" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding TypeLabel}"
                                                   TextColor="{StaticResource SageDark}"
                                                   FontSize="9"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </Grid>
                                    <VerticalStackLayout Grid.Row="1"
                                                         Padding="11,10"
                                                         Spacing="6">
                                        <Label Text="{Binding Title}"
                                               TextColor="{StaticResource BodyText}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               LineBreakMode="WordWrap"
                                               MaxLines="4" />
                                        <Label Text="{Binding SourceLine}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="10"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <controls:BottomNavigationBar Grid.Row="1"
                                      ActiveTab="Home" />
    </Grid>
</ContentPage>
