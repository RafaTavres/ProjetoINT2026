<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             x:Class="ProjetoINT2026.Pages.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF8">

    <ContentPage.Resources>
        <Color x:Key="Sage">#AFC0A3</Color>
        <Color x:Key="SageDark">#66745C</Color>
        <Color x:Key="BodyText">#343A32</Color>
        <Color x:Key="SoftText">#7E877A</Color>
        <Color x:Key="Line">#E4E7E0</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,86">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="28,42,28,24"
                                 Spacing="18">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Home"
                           TextColor="{StaticResource SageDark}"
                           FontSize="32"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold" />
                    <Label Text="Atualizacoes e lembretes de estudo"
                           TextColor="{StaticResource SoftText}"
                           FontSize="13" />
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Resumo do plantao"
                               TextColor="{StaticResource SageDark}"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="Revise sinais vitais, triagem e anotacoes importantes antes da proxima simulacao."
                               TextColor="{StaticResource BodyText}"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                        <Label Text="Hoje · Enfermagem"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Caso para treinar"
                               TextColor="{StaticResource SageDark}"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="Paciente relata tontura e sudorese. Monte uma abordagem inicial e registre os dados essenciais."
                               TextColor="{StaticResource BodyText}"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                        <Label Text="Simulacao · Prioridade media"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Dica rapida"
                               TextColor="{StaticResource SageDark}"
                               FontSize="17"
                               FontAttributes="Bold" />
                        <Label Text="Use a aba Notas para organizar os protocolos em markdown e compartilhar seus resumos."
                               TextColor="{StaticResource BodyText}"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                        <Label Text="Notas · Markdown"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavigationBar Grid.Row="1"
                                      ActiveTab="Home" />
    </Grid>
</ContentPage>
