<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             xmlns:pages="clr-namespace:ProjetoINT2026.Pages"
             x:Class="ProjetoINT2026.Pages.PatientsPage"
             x:DataType="pages:PatientsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FCFCFA">

    <ContentPage.Resources>
        <Color x:Key="Sage">#8FAA87</Color>
        <Color x:Key="SageSoft">#DDE7DA</Color>
        <Color x:Key="SagePale">#EEF4EC</Color>
        <Color x:Key="OliveText">#536B50</Color>
        <Color x:Key="BodyText">#20251F</Color>
        <Color x:Key="SoftText">#777D75</Color>
        <Color x:Key="Line">#E1E5DD</Color>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="*,88">
            <Grid x:Name="PatientListView"
                  Grid.Row="0"
                  RowDefinitions="148,56,*"
                  Padding="26,36,26,0">
                <Grid RowDefinitions="Auto,*">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Plantão"
                               TextColor="{StaticResource OliveText}"
                               FontSize="36"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold" />
                        <Label Text="Escolha um caso, tome decisões e revise sua nota"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>

                    <Border Grid.Row="1"
                            BackgroundColor="#EEF4EC"
                            Stroke="#DDE7DA"
                            StrokeThickness="1"
                            Padding="14,10"
                            VerticalOptions="End">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Missão do plantão"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Label Text="Investigue, diagnostique e finalize para ganhar XP"
                                       TextColor="{StaticResource SoftText}"
                                       FontSize="11"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource SageSoft}"
                                    StrokeThickness="1"
                                    Padding="10,5"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Label Text="4 casos"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="12"
                                       FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        HeightRequest="50"
                        Padding="15,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="26,*"
                          ColumnSpacing="8">
                        <Image Source="icon_search.svg"
                               HeightRequest="20"
                               WidthRequest="20"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Placeholder="Buscar caso..."
                               PlaceholderColor="{StaticResource SoftText}"
                               TextColor="{StaticResource BodyText}"
                               FontSize="15"
                               BackgroundColor="Transparent"
                               ClearButtonVisibility="WhileEditing"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Patients}"
                                SelectionMode="None"
                                Margin="0,14,0,12">
                    <CollectionView.Footer>
                        <BoxView HeightRequest="18"
                                 Color="Transparent" />
                    </CollectionView.Footer>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pages:PatientCase">
                            <Border BackgroundColor="{Binding CardBackgroundColor}"
                                    Stroke="{Binding CardStrokeColor}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPatientTapped" />
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="#22000000"
                                            Offset="0,6"
                                            Radius="14"
                                            Opacity="0.16" />
                                </Border.Shadow>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Grid RowDefinitions="Auto,Auto"
                                      RowSpacing="12">
                                    <Grid ColumnDefinitions="58,*,82"
                                          ColumnSpacing="14">
                                    <Border BackgroundColor="{Binding CaseIconBackgroundColor}"
                                            StrokeThickness="0"
                                            HeightRequest="54"
                                            WidthRequest="54"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="27" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaseIconText}"
                                               TextColor="{Binding CaseIconTextColor}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource BodyText}"
                                               FontSize="19"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CaseSummary}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StatusLine}"
                                               TextColor="{StaticResource OliveText}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="5"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Center">
                                        <Border BackgroundColor="{Binding DifficultyBackgroundColor}"
                                                StrokeThickness="0"
                                                Padding="8,3">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Difficulty}"
                                                   TextColor="{Binding DifficultyTextColor}"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center" />
                                        </Border>
                                        <Label Text="{Binding ScoreLine}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="11"
                                               HorizontalOptions="End" />
                                        <Border BackgroundColor="{Binding ActionBadgeBackgroundColor}"
                                                StrokeThickness="0"
                                                Padding="9,4"
                                                HorizontalOptions="End">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="11" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding ListActionLabel}"
                                                   TextColor="{Binding StatusTextColor}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End" />
                                        </Border>
                                    </VerticalStackLayout>
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <ProgressBar Progress="{Binding ProgressValue}"
                                                     ProgressColor="{Binding CaseProgressColor}"
                                                     BackgroundColor="#E8EEE5"
                                                     HeightRequest="7"
                                                     VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding StepSummary}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="11"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid x:Name="PatientDetailView"
                  Grid.Row="0"
                  IsVisible="False"
                  RowDefinitions="104,50,*"
                  Padding="18,30,18,0">
                <Grid ColumnDefinitions="42,50,*,Auto"
                      ColumnSpacing="12"
                      Padding="0,4,0,0">
                    <Border BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            HeightRequest="40"
                            WidthRequest="40"
                            HorizontalOptions="Start"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToPatientsTapped" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Image Source="icon_back.svg"
                               HeightRequest="22"
                               WidthRequest="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Grid Grid.Column="1"
                          HeightRequest="48"
                          WidthRequest="48"
                          VerticalOptions="Center">
                        <Ellipse Fill="{StaticResource SagePale}" />
                        <Ellipse Fill="{StaticResource Sage}"
                                 HeightRequest="18"
                                 WidthRequest="18"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Start"
                                 Margin="0,8,0,0" />
                        <Ellipse Fill="{StaticResource Sage}"
                                 HeightRequest="27"
                                 WidthRequest="35"
                                 HorizontalOptions="Center"
                                 VerticalOptions="End"
                                 Margin="0,0,0,6" />
                    </Grid>

                    <VerticalStackLayout Grid.Column="2"
                                         Spacing="1"
                                         VerticalOptions="Center">
                        <Label Text="Caso clinico"
                               TextColor="{StaticResource OliveText}"
                               FontSize="11"
                               FontAttributes="Bold" />
                        <Label x:Name="PatientNameLabel"
                               TextColor="{StaticResource BodyText}"
                               FontSize="24"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="PatientMetaLabel"
                               TextColor="{StaticResource BodyText}"
                               FontSize="12"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="CaseProgressLabel"
                               Text="Caso de treino clinico"
                               TextColor="{StaticResource SoftText}"
                               FontSize="11"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Border Grid.Column="3"
                            BackgroundColor="#EEF4EC"
                            Stroke="{StaticResource SageSoft}"
                            StrokeThickness="1"
                            Padding="10,5"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label x:Name="HeaderStatusLabel"
                               TextColor="{StaticResource OliveText}"
                               FontSize="11"
                               FontAttributes="Bold" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Border x:Name="SummaryTab"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSummaryTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="SummaryTabLabel"
                                   Text="Resumo"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="SummaryTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoryTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="HistoryTabLabel"
                                   Text="Historico"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="HistoryTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNotesTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="NotesTabLabel"
                                   Text="Anotações"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="NotesTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,12,0,0">
                    <ScrollView x:Name="SummaryContent">
                        <VerticalStackLayout Spacing="12"
                                             Padding="0,0,0,92">
                            <Border BackgroundColor="#EEF4EC"
                                    Stroke="#DDE7DA"
                                    StrokeThickness="1"
                                    Padding="18,16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="Missão do caso"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="18"
                                                   FontAttributes="Bold" />
                                            <Label Text="Complete as etapas para desbloquear a revisão final"
                                                   TextColor="{StaticResource SoftText}"
                                                   FontSize="11" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="0"
                                                             HorizontalOptions="End">
                                            <Label x:Name="CaseScoreLabel"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End" />
                                            <Label x:Name="CaseRewardLabel"
                                                   TextColor="{StaticResource SoftText}"
                                                   FontSize="11"
                                                   HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <ProgressBar x:Name="CaseProgressBar"
                                                 ProgressColor="{StaticResource Sage}"
                                                 BackgroundColor="#DDE7DA"
                                                 HeightRequest="8" />

                                    <Grid RowDefinitions="Auto,Auto"
                                          ColumnDefinitions="*,*,*"
                                          ColumnSpacing="8"
                                          RowSpacing="6">
                                        <Border x:Name="ExamStepChip"
                                                BackgroundColor="#FFFFFF"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="8,7">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <HorizontalStackLayout Spacing="6"
                                                                   HorizontalOptions="Center">
                                                <Label x:Name="ExamStepLabel"
                                                       Text="1"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <Label Text="Exame"
                                                       TextColor="{StaticResource SoftText}"
                                                       FontSize="11"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>

                                        <Border x:Name="DiagnosisStepChip"
                                                Grid.Column="1"
                                                BackgroundColor="#FFFFFF"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="8,7">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <HorizontalStackLayout Spacing="6"
                                                                   HorizontalOptions="Center">
                                                <Label x:Name="DiagnosisStepLabel"
                                                       Text="2"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <Label Text="Hipótese"
                                                       TextColor="{StaticResource SoftText}"
                                                       FontSize="11"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>

                                        <Border x:Name="TreatmentStepChip"
                                                Grid.Column="2"
                                                BackgroundColor="#FFFFFF"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="8,7">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <HorizontalStackLayout Spacing="6"
                                                                   HorizontalOptions="Center">
                                                <Label x:Name="TreatmentStepLabel"
                                                       Text="3"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <Label Text="Conduta"
                                                       TextColor="{StaticResource SoftText}"
                                                       FontSize="11"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>

                                    <Border BackgroundColor="#FFFFFF"
                                            Stroke="{StaticResource SageSoft}"
                                            StrokeThickness="1"
                                            Padding="12,9">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <Label x:Name="CaseActionStateLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="12"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="XP ao encerrar"
                                                   Grid.Column="1"
                                                   TextColor="{StaticResource SoftText}"
                                                   FontSize="11"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="FinalReportCard"
                                    IsVisible="False"
                                    BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Sage}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="9">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="Resultado final"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="18"
                                                   FontAttributes="Bold" />
                                            <Label Text="Caso bloqueado para revisão"
                                                   TextColor="{StaticResource SoftText}"
                                                   FontSize="11" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1"
                                                BackgroundColor="#EEF4EC"
                                                Stroke="{StaticResource SageSoft}"
                                                StrokeThickness="1"
                                                Padding="12,6">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>
                                            <Label x:Name="FinalGradeLabel"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                    <Label x:Name="FinalReportLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Pistas clínicas"
                                               TextColor="{StaticResource OliveText}"
                                               FontSize="17"
                                               FontAttributes="Bold" />
                                        <Label Text="leia antes de agir"
                                               Grid.Column="1"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="11"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="12"
                                          RowSpacing="12">
                                        <VerticalStackLayout Spacing="5">
                                            <Label Text="Queixa"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="ComplaintLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="14"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="5">
                                            <Label Text="Sinais vitais"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="VitalsLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Row="1"
                                                             Spacing="5">
                                            <Label Text="Cuidados iniciais"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="InitialCareLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Row="1"
                                                             Grid.Column="1"
                                                             Spacing="5">
                                            <Label Text="Alergias"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="AllergiesLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="Sua decisão"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="5">
                                            <Label Text="Diagnóstico"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="DiagnosisLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="5">
                                            <Label Text="Conduta"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="12"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="CareLabel"
                                                   TextColor="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Registro de ações"
                                               TextColor="{StaticResource BodyText}"
                                               FontSize="17"
                                               FontAttributes="Bold" />
                                        <Label x:Name="ActionLogCountLabel"
                                               Grid.Column="1"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="12"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <VerticalStackLayout x:Name="ActionLogStack"
                                                         Spacing="8" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView x:Name="HistoryContent"
                                IsVisible="False">
                        <VerticalStackLayout x:Name="HistoryStack"
                                             Spacing="12"
                                             Padding="0,0,0,92" />
                    </ScrollView>

                    <ScrollView x:Name="NotesContent"
                                IsVisible="False">
                        <VerticalStackLayout Spacing="14"
                                             Padding="0,0,0,92">
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="Caderno do caso"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="18"
                                                   FontAttributes="Bold" />
                                            <Label x:Name="NotesStatusLabel"
                                                   Text="Registre hipóteses e sinais que sustentam sua decisão"
                                                   TextColor="{StaticResource SoftText}"
                                                   FontSize="11" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <FlexLayout Wrap="Wrap"
                                                Direction="Row"
                                                AlignItems="Start"
                                                JustifyContent="Start">
                                        <Border BackgroundColor="#EEF4EC"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="10,5"
                                                Margin="0,0,8,8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Label Text="Hipótese"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                        </Border>
                                        <Border BackgroundColor="#EEF4EC"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="10,5"
                                                Margin="0,0,8,8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Label Text="Sinais"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                        </Border>
                                        <Border BackgroundColor="#EEF4EC"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="10,5"
                                                Margin="0,0,8,8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Label Text="Exames"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                        </Border>
                                        <Border BackgroundColor="#EEF4EC"
                                                Stroke="#DDE7DA"
                                                StrokeThickness="1"
                                                Padding="10,5"
                                                Margin="0,0,8,8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Label Text="Conduta"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </FlexLayout>

                                    <Editor x:Name="PatientNotesEditor"
                                            TextChanged="OnPatientNotesChanged"
                                            TextColor="{StaticResource BodyText}"
                                            FontSize="15"
                                            AutoSize="TextChanges"
                                            HeightRequest="270"
                                            BackgroundColor="#FAFBF8"
                                            Placeholder="Anote raciocínio, hipóteses, condutas e pontos de estudo..."
                                            PlaceholderColor="{StaticResource SoftText}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>

                <Border x:Name="FloatingActionButton"
                        Grid.Row="2"
                        BackgroundColor="{StaticResource Sage}"
                        StrokeThickness="0"
                        HeightRequest="54"
                        WidthRequest="168"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Margin="0,0,8,18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnActionsTapped" />
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="27" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="28,*"
                          ColumnSpacing="6"
                          Padding="14,0">
                        <Image Source="icon_case_actions.svg"
                               HeightRequest="21"
                               WidthRequest="21"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label x:Name="FloatingActionLabel"
                               Grid.Column="1"
                               Text="Ações do caso"
                               TextColor="White"
                               FontSize="13"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <Border.Shadow>
                        <Shadow Brush="#33000000"
                                Offset="0,8"
                                Radius="16"
                                Opacity="0.24" />
                    </Border.Shadow>
                </Border>
            </Grid>

            <controls:BottomNavigationBar Grid.Row="1"
                                          ActiveTab="Patients" />
        </Grid>

        <Grid x:Name="ActionMenu"
              IsVisible="False"
              BackgroundColor="#66000000"
              Padding="28">
            <Border BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    Padding="18"
                    VerticalOptions="End"
                    Margin="0,0,0,92">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Escolha sua ação"
                           TextColor="{StaticResource OliveText}"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label x:Name="ActionMenuStatusLabel"
                           Text="Cada escolha fica registrada e influencia sua nota final."
                           TextColor="{StaticResource SoftText}"
                           FontSize="12" />

                    <Border x:Name="ActionProgressCard"
                            IsVisible="False"
                            BackgroundColor="#EEF4EC"
                            Stroke="{StaticResource SageSoft}"
                            StrokeThickness="1"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="9">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="1">
                                    <Label Text="Em andamento"
                                           TextColor="{StaticResource OliveText}"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                    <Label x:Name="PendingActionTitleLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Label x:Name="PendingActionCountdownLabel"
                                       Grid.Column="1"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </Grid>

                            <ProgressBar x:Name="PendingActionProgressBar"
                                         ProgressColor="{StaticResource Sage}"
                                         BackgroundColor="#DDE7DA"
                                         HeightRequest="7" />

                            <Label x:Name="PendingActionDetailLabel"
                                   TextColor="{StaticResource SoftText}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid x:Name="ActionOptionsGrid"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <Border x:Name="ExamActionCard"
                                BackgroundColor="#EEF4EC"
                                Stroke="#DDE7DA"
                                StrokeThickness="1"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnExamActionTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="ExamActionTitleLabel"
                                       Text="Solicitar exame"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label x:Name="ExamActionSubtitleLabel"
                                       Text="+20 se prioritario"
                                       TextColor="{StaticResource SoftText}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="DiagnosisActionCard"
                                Grid.Column="1"
                                BackgroundColor="{StaticResource Sage}"
                                StrokeThickness="0"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDiagnoseActionTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="DiagnosisActionTitleLabel"
                                       Text="Registrar hipótese"
                                       TextColor="White"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Label x:Name="DiagnosisActionSubtitleLabel"
                                       Text="+40 se correto"
                                       TextColor="#F7FBF5"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="TreatmentActionCard"
                                Grid.Row="1"
                                BackgroundColor="#EEF4EC"
                                Stroke="#DDE7DA"
                                StrokeThickness="1"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTreatmentActionTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="TreatmentActionTitleLabel"
                                       Text="Definir conduta"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label x:Name="TreatmentActionSubtitleLabel"
                                       Text="+30 se seguro"
                                       TextColor="{StaticResource SoftText}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="FinishActionCard"
                                Grid.Row="1"
                                Grid.Column="1"
                                BackgroundColor="#F8FAF6"
                                Stroke="{StaticResource Line}"
                                StrokeThickness="1"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFinishActionTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="FinishActionTitleLabel"
                                       Text="Finalizar caso"
                                       TextColor="{StaticResource OliveText}"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label x:Name="FinishActionSubtitleLabel"
                                       Text="gera nota final"
                                       TextColor="{StaticResource SoftText}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#FAFBF8"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            Padding="12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label x:Name="ActionMenuLastActionLabel"
                               Text="Nenhuma ação registrada ainda."
                               TextColor="{StaticResource SoftText}"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </Border>

                    <Button Text="Fechar"
                            Clicked="OnCancelActionsClicked"
                            BackgroundColor="#FFFFFF"
                            BorderColor="{StaticResource Line}"
                            BorderWidth="1"
                            TextColor="{StaticResource SoftText}"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="42" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <controls:AppModalHost x:Name="ModalHost"
                               ZIndex="200" />
    </Grid>
</ContentPage>
