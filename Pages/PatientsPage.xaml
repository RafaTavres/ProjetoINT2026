<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             xmlns:pages="clr-namespace:ProjetoINT2026.Pages"
             x:Class="ProjetoINT2026.Pages.PatientsPage"
             x:DataType="pages:PatientsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FCFCFA">

    <ContentPage.Resources>
        <Color x:Key="Sage">#8FAA87</Color>
        <Color x:Key="SageSoft">#DDE7DA</Color>
        <Color x:Key="SagePale">#EEF4EC</Color>
        <Color x:Key="OliveText">#536B50</Color>
        <Color x:Key="BodyText">#20251F</Color>
        <Color x:Key="SoftText">#777D75</Color>
        <Color x:Key="Line">#E1E5DD</Color>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="*,86">
            <Grid x:Name="PatientListView"
                  Grid.Row="0"
                  RowDefinitions="92,58,*"
                  Padding="26,36,26,0">
                <Grid ColumnDefinitions="*,52">
                    <VerticalStackLayout Spacing="0"
                                         VerticalOptions="Center">
                        <Label Text="Plantao"
                               TextColor="{StaticResource OliveText}"
                               FontSize="36"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold" />
                        <Label Text="Resolva casos clinicos e ganhe XP"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="48"
                            WidthRequest="48"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGenerateCaseTapped" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Label Text="+"
                               TextColor="White"
                               FontSize="34"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,-4,0,0" />
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        HeightRequest="50"
                        Padding="15,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="26,*"
                          ColumnSpacing="8">
                        <Image Source="icon_search.svg"
                               HeightRequest="20"
                               WidthRequest="20"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Placeholder="Buscar paciente..."
                               PlaceholderColor="{StaticResource SoftText}"
                               TextColor="{StaticResource BodyText}"
                               FontSize="15"
                               BackgroundColor="Transparent"
                               ClearButtonVisibility="WhileEditing"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Patients}"
                                SelectionMode="None"
                                Margin="0,14,0,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pages:PatientCase">
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPatientTapped" />
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="#22000000"
                                            Offset="0,6"
                                            Radius="14"
                                            Opacity="0.16" />
                                </Border.Shadow>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="58,*,54"
                                      ColumnSpacing="14">
                                    <Grid HeightRequest="54"
                                          WidthRequest="54">
                                        <Ellipse Fill="{StaticResource SagePale}" />
                                        <Ellipse Fill="{StaticResource Sage}"
                                                 HeightRequest="21"
                                                 WidthRequest="21"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Start"
                                                 Margin="0,9,0,0" />
                                        <Ellipse Fill="{StaticResource Sage}"
                                                 HeightRequest="31"
                                                 WidthRequest="40"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="End"
                                                 Margin="0,0,0,6" />
                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource BodyText}"
                                               FontSize="19"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CaseSummary}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StatusLine}"
                                               TextColor="{StaticResource OliveText}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="5"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Center">
                                        <Border BackgroundColor="{StaticResource SagePale}"
                                                StrokeThickness="0"
                                                Padding="8,3">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Difficulty}"
                                                   TextColor="{StaticResource OliveText}"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center" />
                                        </Border>
                                        <Label Text="{Binding ScoreLine}"
                                               TextColor="{StaticResource SoftText}"
                                               FontSize="11"
                                               HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid x:Name="PatientDetailView"
                  Grid.Row="0"
                  IsVisible="False"
                  RowDefinitions="112,50,*"
                  Padding="22,34,22,0">
                <Grid ColumnDefinitions="36,*,44"
                      RowDefinitions="38,54">
                    <Label Text="&lt;"
                           TextColor="{StaticResource Sage}"
                           FontSize="30"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToPatientsTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label x:Name="PatientNameLabel"
                           Grid.Column="1"
                           TextColor="{StaticResource BodyText}"
                           FontSize="26"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation" />

                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="40"
                            WidthRequest="40"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnActionsTapped" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="+"
                               TextColor="White"
                               FontSize="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,-4,0,0" />
                    </Border>

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.ColumnSpan="3"
                                         Spacing="2"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label x:Name="PatientMetaLabel"
                               TextColor="{StaticResource BodyText}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                        <Label x:Name="CaseProgressLabel"
                               Text="Caso de treino clinico"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Border x:Name="SummaryTab"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSummaryTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="SummaryTabLabel"
                                   Text="Resumo"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="SummaryTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoryTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="HistoryTabLabel"
                                   Text="Historico"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="HistoryTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNotesTabTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center">
                            <Label x:Name="NotesTabLabel"
                                   Text="Anotacoes"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                            <BoxView x:Name="NotesTabLine"
                                     HeightRequest="3"
                                     WidthRequest="76"
                                     CornerRadius="2"
                                     HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,12,0,0">
                    <ScrollView x:Name="SummaryContent">
                        <VerticalStackLayout Spacing="12"
                                             Padding="0,0,0,18">
                            <Border BackgroundColor="#EEF4EC"
                                    Stroke="#DDE7DA"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <Label Text="Desempenho"
                                           TextColor="{StaticResource OliveText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label x:Name="CaseScoreLabel"
                                           Grid.Column="1"
                                           TextColor="{StaticResource OliveText}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           HorizontalOptions="End" />
                                    <Label x:Name="CaseActionStateLabel"
                                           Grid.Row="1"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="13"
                                           LineBreakMode="WordWrap" />
                                    <Label x:Name="CaseRewardLabel"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           TextColor="{StaticResource SoftText}"
                                           FontSize="13"
                                           HorizontalOptions="End" />
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Sinais vitais"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label x:Name="VitalsLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="14"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Queixa principal"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label x:Name="ComplaintLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="14" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Diagnostico"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label x:Name="DiagnosisLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="14" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Cuidados"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="17"
                                           FontAttributes="Bold" />
                                    <Label x:Name="CareLabel"
                                           TextColor="{StaticResource BodyText}"
                                           FontSize="14"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView x:Name="HistoryContent"
                                IsVisible="False">
                        <VerticalStackLayout x:Name="HistoryStack"
                                             Spacing="12"
                                             Padding="0,0,0,18" />
                    </ScrollView>

                    <ScrollView x:Name="NotesContent"
                                IsVisible="False">
                        <VerticalStackLayout Spacing="14"
                                             Padding="0,0,0,18">
                            <Editor x:Name="PatientNotesEditor"
                                    TextChanged="OnPatientNotesChanged"
                                    TextColor="{StaticResource BodyText}"
                                    FontSize="15"
                                    AutoSize="TextChanges"
                                    HeightRequest="260"
                                    BackgroundColor="#FFFFFF"
                                    Placeholder="Anote raciocinio, hipoteses, condutas e pontos de estudo..."
                                    PlaceholderColor="{StaticResource SoftText}" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Grid>

            <controls:BottomNavigationBar Grid.Row="1"
                                          ActiveTab="Patients" />
        </Grid>

        <Grid x:Name="ActionMenu"
              IsVisible="False"
              BackgroundColor="#66000000"
              Padding="28">
            <Border BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    Padding="18"
                    VerticalOptions="End"
                    Margin="0,0,0,92">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Acoes do treino"
                           TextColor="{StaticResource OliveText}"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="Escolha uma etapa. O caso pontua precisao, seguranca e eficiencia."
                           TextColor="{StaticResource SoftText}"
                           FontSize="12" />
                    <Button Text="Solicitar exame"
                            Clicked="OnExamClicked"
                            BackgroundColor="#EEF4EC"
                            TextColor="{StaticResource OliveText}"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="44" />
                    <Button Text="Diagnosticar"
                            Clicked="OnDiagnoseClicked"
                            BackgroundColor="{StaticResource Sage}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="44" />
                    <Button Text="Receitar tratamento"
                            Clicked="OnTreatmentClicked"
                            BackgroundColor="#EEF4EC"
                            TextColor="{StaticResource OliveText}"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="44" />
                    <Button Text="Encerrar caso"
                            Clicked="OnFinishCaseClicked"
                            BackgroundColor="#EEF4EC"
                            TextColor="{StaticResource OliveText}"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="44" />
                    <Button Text="Cancelar"
                            Clicked="OnCancelActionsClicked"
                            BackgroundColor="#FFFFFF"
                            BorderColor="{StaticResource Line}"
                            BorderWidth="1"
                            TextColor="{StaticResource SoftText}"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="42" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
