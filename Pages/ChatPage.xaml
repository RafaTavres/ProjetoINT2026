<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             xmlns:pages="clr-namespace:ProjetoINT2026.Pages"
             x:Class="ProjetoINT2026.Pages.ChatPage"
             x:DataType="pages:ChatPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF8">

    <ContentPage.Resources>
        <Color x:Key="Sage">#AFC0A3</Color>
        <Color x:Key="SageDark">#66745C</Color>
        <Color x:Key="BodyText">#343A32</Color>
        <Color x:Key="SoftText">#7E877A</Color>
        <Color x:Key="Line">#E4E7E0</Color>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="*,88">
            <Grid Grid.Row="0"
                  RowDefinitions="108,*,Auto"
                  Padding="24,34,24,0">
            <Grid ColumnDefinitions="54,*"
                  ColumnSpacing="12"
                  VerticalOptions="Center">
                <Border BackgroundColor="#EEF4EC"
                        Stroke="#DDE7DA"
                        StrokeThickness="1"
                        HeightRequest="48"
                        WidthRequest="48"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Image Source="icon_chat.svg"
                           HeightRequest="27"
                           WidthRequest="27"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="Florence"
                           TextColor="{StaticResource SageDark}"
                           FontSize="32"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold" />
                    <Label Text="Converse com a Florence"
                           TextColor="{StaticResource SoftText}"
                           FontSize="13" />
                </VerticalStackLayout>
            </Grid>

            <CollectionView x:Name="MessagesCollection"
                            Grid.Row="1"
                            ItemsSource="{Binding Messages}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="pages:ChatMessage">
                        <Grid Padding="0,3"
                              ColumnDefinitions="34,*"
                              ColumnSpacing="8">
                            <Border IsVisible="{Binding IsAssistant}"
                                    BackgroundColor="#EEF4EC"
                                    Stroke="#DDE7DA"
                                    StrokeThickness="1"
                                    HeightRequest="30"
                                    WidthRequest="30"
                                    VerticalOptions="Start"
                                    Margin="0,3,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                <Label Text="F"
                                       TextColor="{StaticResource SageDark}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="{Binding BubbleColor}"
                                    Stroke="{Binding BubbleStrokeColor}"
                                    StrokeThickness="1"
                                    Padding="17,13"
                                    MinimumWidthRequest="120"
                                    MaximumWidthRequest="338"
                                    HorizontalOptions="{Binding BubbleHorizontalOptions}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMessageTapped" />
                                </Border.GestureRecognizers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="5">
                                    <Label Text="{Binding Sender}"
                                           IsVisible="{Binding IsAssistant}"
                                           TextColor="{Binding SenderColor}"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Text}"
                                           TextColor="{Binding TextColor}"
                                           FontSize="15"
                                           LineBreakMode="WordWrap" />
                                    <Border IsVisible="{Binding ShowSaveAsNote}"
                                            BackgroundColor="#EEF4EC"
                                            Stroke="#DCE6D8"
                                            StrokeThickness="1"
                                            HeightRequest="28"
                                            Padding="10,0"
                                            HorizontalOptions="End"
                                            Margin="0,6,0,0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSaveAsNoteTapped" />
                                        </Border.GestureRecognizers>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5"
                                                               VerticalOptions="Center">
                                            <Image Source="icon_add_note.svg"
                                                   HeightRequest="14"
                                                   WidthRequest="14"
                                                   VerticalOptions="Center" />
                                            <Label Text="Nota"
                                                   TextColor="{StaticResource SageDark}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto,54"
                  ColumnDefinitions="46,*,54"
                  ColumnSpacing="8"
                  RowSpacing="8"
                  Padding="0,4,0,10">
                <Border x:Name="AttachmentChip"
                        Grid.ColumnSpan="3"
                        IsVisible="False"
                        BackgroundColor="#EEF4EC"
                        Stroke="#DDE7DA"
                        StrokeThickness="1"
                        Padding="12,0"
                        HeightRequest="34">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,30">
                        <Label x:Name="AttachmentLabel"
                               TextColor="{StaticResource SageDark}"
                               FontSize="12"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Column="1"
                               Text="x"
                               TextColor="{StaticResource SoftText}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRemoveAttachmentTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Label Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Text="Florence está digitando..."
                       TextColor="{StaticResource SoftText}"
                       FontSize="12"
                       IsVisible="{Binding IsResponding}"
                       Margin="10,0,0,0" />

                <Border Grid.Row="2"
                        BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        HeightRequest="48"
                        WidthRequest="46">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAttachFileTapped" />
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="23" />
                    </Border.StrokeShape>
                    <Image Source="icon_attach.svg"
                           HeightRequest="21"
                           WidthRequest="21"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="1"
                        BackgroundColor="#FFFFFF"
                        Stroke="{StaticResource Line}"
                        StrokeThickness="1"
                        Padding="16,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Entry x:Name="MessageEntry"
                           Placeholder="Mensagem para Florence..."
                           PlaceholderColor="{StaticResource SoftText}"
                           TextColor="{StaticResource BodyText}"
                           FontSize="15"
                           BackgroundColor="Transparent"
                           ReturnType="Send"
                           Completed="OnMessageCompleted"
                           VerticalOptions="Center" />
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="2"
                        BackgroundColor="{StaticResource Sage}"
                        StrokeThickness="0"
                        HeightRequest="48"
                        WidthRequest="50"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSendTapped" />
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Image Source="icon_send.svg"
                           HeightRequest="21"
                           WidthRequest="21"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Grid>

            <controls:BottomNavigationBar Grid.Row="1"
                                          ActiveTab="Chat" />
        </Grid>

        <Grid x:Name="SaveNotePopup"
              IsVisible="False"
              BackgroundColor="#99000000"
              Padding="28">
            <Border BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    Padding="18"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Salvar resposta"
                               TextColor="{StaticResource SageDark}"
                               FontSize="21"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold" />
                        <Label Text="Escolha onde essa nota será guardada"
                               TextColor="{StaticResource SoftText}"
                               FontSize="12" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#FAFBF8"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            Padding="12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label x:Name="SaveNotePreviewLabel"
                               TextColor="{StaticResource BodyText}"
                               FontSize="13"
                               LineBreakMode="TailTruncation"
                               MaxLines="3" />
                    </Border>

                    <VerticalStackLayout Spacing="7">
                        <Label Text="Pasta"
                               TextColor="{StaticResource BodyText}"
                               FontSize="12"
                               FontAttributes="Bold" />
                        <CollectionView x:Name="SaveFolderCollection"
                                        ItemsSource="{Binding SaveFolderOptions}"
                                        SelectionMode="None"
                                        HeightRequest="142">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pages:SaveFolderOption">
                                    <Border BackgroundColor="{Binding BackgroundColor}"
                                            Stroke="{Binding StrokeColor}"
                                            StrokeThickness="1"
                                            Padding="12,0"
                                            HeightRequest="36">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSaveFolderTapped" />
                                        </Border.GestureRecognizers>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="9" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Name}"
                                               TextColor="{Binding TextColor}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Text="Cancelar"
                                Clicked="OnCancelSaveNoteClicked"
                                BackgroundColor="#FFFFFF"
                                BorderColor="{StaticResource Line}"
                                BorderWidth="1"
                                TextColor="{StaticResource SageDark}"
                                FontSize="13"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="44" />
                        <Button Grid.Column="1"
                                Text="Salvar"
                                Clicked="OnConfirmSaveNoteClicked"
                                BackgroundColor="{StaticResource Sage}"
                                TextColor="White"
                                FontSize="13"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="44" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <controls:AppModalHost x:Name="ModalHost"
                               ZIndex="200" />
    </Grid>
</ContentPage>
