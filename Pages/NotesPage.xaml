<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProjetoINT2026.Controls"
             xmlns:pages="clr-namespace:ProjetoINT2026.Pages"
             x:Class="ProjetoINT2026.Pages.NotesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF8">

    <ContentPage.Resources>
        <Color x:Key="Sage">#AFC0A3</Color>
        <Color x:Key="SageDark">#718066</Color>
        <Color x:Key="OliveText">#66745C</Color>
        <Color x:Key="BodyText">#343A32</Color>
        <Color x:Key="PanelFill">#F1F2EF</Color>
        <Color x:Key="Line">#E0E3DC</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,86">
        <Grid Grid.Row="0"
              RowDefinitions="64,70,84,*"
              Padding="22,28,22,0">
            <VerticalStackLayout Spacing="1"
                                 VerticalOptions="Center">
                <Label Text="Minhas Notas"
                       TextColor="{StaticResource OliveText}"
                       FontSize="25"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold" />
                <Label x:Name="StatusLabel"
                       Text="Editando Anatomia 01"
                       TextColor="#8A9284"
                       FontSize="11"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  RowDefinitions="28,36"
                  RowSpacing="4"
                  Margin="0,6,0,0">
                <Grid ColumnDefinitions="*,36,36"
                      ColumnSpacing="8">
                    <VerticalStackLayout Spacing="0"
                                         VerticalOptions="Center">
                        <Label Text="Pastas"
                               TextColor="{StaticResource BodyText}"
                               FontSize="13"
                               FontAttributes="Bold" />
                        <Label Text="Organize por assunto"
                               TextColor="#7E877A"
                               FontSize="10"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            HeightRequest="32"
                            WidthRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddFolderClicked" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="icon_add_note.svg"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            HeightRequest="32"
                            WidthRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDeleteFolderClicked" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="icon_trash.svg"
                               HeightRequest="17"
                               WidthRequest="17"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <CollectionView x:Name="FoldersCollection"
                                Grid.Row="1"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pages:FolderItem">
                            <Border BackgroundColor="{Binding BackgroundColor}"
                                    Stroke="{Binding StrokeColor}"
                                    StrokeThickness="1"
                                    Padding="12,0"
                                    HeightRequest="32"
                                    WidthRequest="128">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFolderTapped" />
                                </Border.GestureRecognizers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Name}"
                                       TextColor="{Binding TextColor}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid Grid.Row="2"
                  RowDefinitions="34,38"
                  RowSpacing="6"
                  Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,36,36,36"
                      ColumnSpacing="8">
                    <VerticalStackLayout Spacing="0"
                                         VerticalOptions="Center">
                        <Label Text="Notas"
                               TextColor="{StaticResource BodyText}"
                               FontSize="15"
                               FontAttributes="Bold" />
                        <Label x:Name="FolderContextLabel"
                               Text="Pasta: Estudos"
                               TextColor="#7E877A"
                               FontSize="10"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="32"
                            WidthRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddNoteClicked" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="icon_add_note.svg"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            HeightRequest="32"
                            WidthRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShareNoteClicked" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="icon_share.svg"
                               HeightRequest="17"
                               WidthRequest="17"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="3"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            HeightRequest="32"
                            WidthRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDeleteNoteClicked" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="icon_trash.svg"
                               HeightRequest="17"
                               WidthRequest="17"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <CollectionView x:Name="NotesCollection"
                                Grid.Row="1"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pages:NoteItem">
                            <Border BackgroundColor="{Binding BackgroundColor}"
                                    Stroke="{Binding StrokeColor}"
                                    StrokeThickness="1"
                                    Padding="12,0"
                                    HeightRequest="34"
                                    WidthRequest="148">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNoteTapped" />
                                </Border.GestureRecognizers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Title}"
                                       TextColor="{Binding TextColor}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Border Grid.Row="3"
                    BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    Padding="16,12"
                    Margin="0,10,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="44,*">
                    <Entry x:Name="TitleEntry"
                           TextChanged="OnTitleChanged"
                           TextColor="{StaticResource SageDark}"
                           FontSize="18"
                           FontAttributes="Bold"
                           IsSpellCheckEnabled="False"
                           Placeholder="nova_nota.md"
                           PlaceholderColor="#A6ADA0"
                           BackgroundColor="Transparent" />

                    <Editor x:Name="NoteEditor"
                            Grid.Row="1"
                            TextChanged="OnContentChanged"
                            TextColor="{StaticResource BodyText}"
                            FontSize="15"
                            AutoSize="Disabled"
                            IsSpellCheckEnabled="False"
                            Placeholder="# Titulo&#10;&#10;Escreva sua nota em markdown..."
                            PlaceholderColor="#A0A79B"
                            BackgroundColor="Transparent" />
                </Grid>
            </Border>
        </Grid>

        <controls:BottomNavigationBar Grid.Row="1"
                                      ActiveTab="Notes" />
    </Grid>
</ContentPage>
