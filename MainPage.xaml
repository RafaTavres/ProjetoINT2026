<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoINT2026.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <ContentPage.Resources>
        <Color x:Key="Sage">#B2BFA2</Color>
        <Color x:Key="SageSoft">#C8D0BE</Color>
        <Color x:Key="OliveText">#777F69</Color>
        <Color x:Key="MutedText">#747A70</Color>
        <Color x:Key="Divider">#ECEEEA</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,86">
        <Grid Grid.Row="0"
              Padding="36,44,28,0">
            <VerticalStackLayout Spacing="30">
                <Label Text="Minhas Notas"
                       TextColor="{StaticResource OliveText}"
                       FontSize="32"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold" />

                <VerticalStackLayout Spacing="30"
                                     Margin="0,70,0,0">
                    <Border BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="76"
                            HorizontalOptions="Fill">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="38" />
                        </Border.StrokeShape>
                        <Label Text="ESTUDO"
                               TextColor="White"
                               FontSize="24"
                               FontAttributes="Bold"
                               CharacterSpacing="3"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Border BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="76"
                            HorizontalOptions="Fill">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="38" />
                        </Border.StrokeShape>
                        <Label Text="NOTA"
                               TextColor="White"
                               FontSize="24"
                               FontAttributes="Bold"
                               CharacterSpacing="3"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Border BackgroundColor="{StaticResource Sage}"
                            StrokeThickness="0"
                            HeightRequest="76"
                            HorizontalOptions="Fill">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="38" />
                        </Border.StrokeShape>
                        <Label Text="TAREFA"
                               TextColor="White"
                               FontSize="24"
                               FontAttributes="Bold"
                               CharacterSpacing="3"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Border BackgroundColor="{StaticResource SageSoft}"
                    StrokeThickness="0"
                    WidthRequest="178"
                    HeightRequest="330"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,-6,0,0"
                    Padding="0,28">
                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,10"
                            Radius="22"
                            Opacity="0.25" />
                </Border.Shadow>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="34" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="28"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout Spacing="6"
                                         HorizontalOptions="Center">
                        <Image Source="icon_add_note.svg"
                               HeightRequest="38"
                               WidthRequest="38" />
                        <Label Text="+ NOTA"
                               TextColor="{StaticResource OliveText}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <Image Source="icon_share.svg"
                               HeightRequest="38"
                               WidthRequest="38" />
                        <Label Text="COMP."
                               TextColor="{StaticResource OliveText}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <Image Source="icon_trash.svg"
                               HeightRequest="38"
                               WidthRequest="38" />
                        <Label Text="APAGAR"
                               TextColor="{StaticResource OliveText}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              RowDefinitions="1,*"
              BackgroundColor="#FFFFFF">
            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource Divider}" />

            <Grid Grid.Row="1"
                  Padding="22,8,22,8"
                  ColumnDefinitions="*,*,*,*">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="2"
                                     HorizontalOptions="Center">
                    <Image Source="icon_patients.svg"
                           HeightRequest="28"
                           WidthRequest="28" />
                    <Label Text="Pacientes"
                           TextColor="{StaticResource MutedText}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     HorizontalOptions="Center">
                    <Image Source="icon_home.svg"
                           HeightRequest="30"
                           WidthRequest="30" />
                    <Label Text="Home"
                           TextColor="{StaticResource MutedText}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     Spacing="2"
                                     HorizontalOptions="Center">
                    <Image Source="icon_chat.svg"
                           HeightRequest="30"
                           WidthRequest="30" />
                    <Label Text="Chat IA"
                           TextColor="{StaticResource MutedText}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3"
                                     Spacing="2"
                                     HorizontalOptions="Center">
                    <Image Source="icon_notes.svg"
                           HeightRequest="30"
                           WidthRequest="30" />
                    <Label Text="Notas"
                           TextColor="{StaticResource Sage}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
