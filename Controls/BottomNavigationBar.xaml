<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoINT2026.Controls.BottomNavigationBar"
             HeightRequest="88"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="1,*"
          BackgroundColor="#FFFFFF">
        <BoxView HeightRequest="1"
                 BackgroundColor="#ECEEEA" />

        <Grid Grid.Row="1"
              Padding="20,7,20,8"
              ColumnDefinitions="*,*,*,*">
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="1"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPatientsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border x:Name="PatientsPill"
                        HeightRequest="34"
                        WidthRequest="50"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17" />
                    </Border.StrokeShape>
                    <Image x:Name="PatientsIcon"
                           Source="icon_cases.svg"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label x:Name="PatientsLabel"
                       Text="Casos"
                       TextColor="#747A70"
                       FontSize="13"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="1"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border x:Name="HomePill"
                        HeightRequest="34"
                        WidthRequest="50"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17" />
                    </Border.StrokeShape>
                    <Image x:Name="HomeIcon"
                           Source="icon_feed.svg"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label x:Name="HomeLabel"
                       Text="Feed"
                       TextColor="#747A70"
                       FontSize="13"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 Spacing="1"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChatTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border x:Name="ChatPill"
                        HeightRequest="34"
                        WidthRequest="50"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17" />
                    </Border.StrokeShape>
                    <Image x:Name="ChatIcon"
                           Source="icon_chat.svg"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label x:Name="ChatLabel"
                       Text="Florence"
                       TextColor="#747A70"
                       FontSize="13"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 Spacing="1"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Border x:Name="NotesPill"
                        HeightRequest="34"
                        WidthRequest="50"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17" />
                    </Border.StrokeShape>
                    <Image x:Name="NotesIcon"
                           Source="icon_notebook.svg"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label x:Name="NotesLabel"
                       Text="Notas"
                       TextColor="#747A70"
                       FontSize="13"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
