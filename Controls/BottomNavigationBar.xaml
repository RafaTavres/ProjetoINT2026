<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoINT2026.Controls.BottomNavigationBar"
             HeightRequest="86"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="1,*"
          BackgroundColor="#FFFFFF">
        <BoxView HeightRequest="1"
                 BackgroundColor="#ECEEEA" />

        <Grid Grid.Row="1"
              Padding="22,8,22,8"
              ColumnDefinitions="*,*,*,*">
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPatientsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="icon_patients.svg"
                       HeightRequest="28"
                       WidthRequest="28" />
                <Label x:Name="PatientsLabel"
                       Text="Pacientes"
                       TextColor="#747A70"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="icon_home.svg"
                       HeightRequest="30"
                       WidthRequest="30" />
                <Label x:Name="HomeLabel"
                       Text="Home"
                       TextColor="#747A70"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChatTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="icon_chat.svg"
                       HeightRequest="30"
                       WidthRequest="30" />
                <Label x:Name="ChatLabel"
                       Text="Florence"
                       TextColor="#747A70"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="icon_notes.svg"
                       HeightRequest="30"
                       WidthRequest="30" />
                <Label x:Name="NotesLabel"
                       Text="Notas"
                       TextColor="#747A70"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
